{
  "name": "polyinsight-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_USE_ENV_PROXY=1 tsx watch src/index.ts",
    "dev:api": "NODE_USE_ENV_PROXY=1 ANALYSIS_WORKER_ENABLED=false tsx watch src/index.ts",
    "dev:worker": "NODE_USE_ENV_PROXY=1 ANALYSIS_WORKER_ENABLED=true tsx watch src/worker.ts",
    "start": "NODE_USE_ENV_PROXY=1 node dist/index.js",
    "start:api": "NODE_USE_ENV_PROXY=1 ANALYSIS_WORKER_ENABLED=false node dist/index.js",
    "start:worker": "NODE_USE_ENV_PROXY=1 ANALYSIS_WORKER_ENABLED=true node dist/worker.js",
    "build": "tsc",
    "test:code-analysis": "NODE_USE_ENV_PROXY=1 tsx src/scripts/testCodeAnalysis.ts",
    "test:n8n-analysis": "NODE_USE_ENV_PROXY=1 tsx src/scripts/testN8nAnalysis.ts"
  },
  "dependencies": {
    "@privy-io/server-auth": "^1.18.0",
    "@supabase/supabase-js": "^2.93.1",
    "cors": "^2.8.5",
    "ethers": "^6.16.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.19.7",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "~5.8.3"
  }
}
